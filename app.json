{
  "expo": {
    "name": "Variable Claw",
    "slug": "VariableClaw",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "variableclaw",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.variableclaw.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Variable Claw needs Bluetooth to connect to your laptop as a keyboard/mouse",
        "NSBluetoothPeripheralUsageDescription": "Variable Claw needs Bluetooth to act as a HID device",
        "NSSpeechRecognitionUsageDescription": "Variable Claw needs speech recognition to process voice commands",
        "NSMicrophoneUsageDescription": "Variable Claw needs microphone access for voice commands"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a1a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.variableclaw.app",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-dev-client",
        {
          "addGeneratedScheme": false
        }
      ],
      "./plugins/with-native-modules"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "803f6002-2c46-4a3b-9027-cdc60a49eb58"
      }
    },
    "owner": "manu_950"
  }
}
